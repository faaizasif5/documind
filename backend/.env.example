APP_ENV=local
APP_NAME=DocuMind API
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000

# App runtime connection (Supabase transaction pooler, port 6543)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/documind
# Alembic migrations connection (Supabase session pooler, port 5432)
DATABASE_MIGRATION_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/documind

# AI provider: "gemini" (free tier) or "openai". Selects which models/keys are used.
LLM_PROVIDER=gemini
# Required when LLM_PROVIDER=gemini (free key from aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=sk-your-openai-api-key

EMBEDDING_DIM=1536
UPLOAD_MAX_BYTES=10485760
